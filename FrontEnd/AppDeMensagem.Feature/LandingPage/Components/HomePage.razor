@using Microsoft.AspNetCore.Components.Routing



<main class="flex flex-col justify-between bg-zinc-100">

	<!-- HERO SECTION (Seção de Destaque) -->
	<section class="mx-auto flex w-full max-w-7xl flex-col-reverse items-center justify-between gap-10 px-6 py-12 md:px-16 lg:flex-row lg:py-20">
		
		<!-- Texto e Chamada para Ação (CTA) -->
		<div class="flex flex-col gap-6 text-center lg:w-1/2 lg:text-left">
			<span class="mx-auto inline-block w-max rounded-full bg-blue-100 px-3 py-1 text-sm font-semibold text-blue-600 lg:mx-0">
				👑 O Mensageiro Definitivo
			</span>

			<h1 class="text-4xl leading-tight font-extrabold text-zinc-800 md:text-6xl">
				Mande msgs como o verdadeiro <span class="text-blue-500">King do Zap Zap</span>
			</h1>

			<p class="text-base text-zinc-600 md:text-lg">
				Conecte-se com seus amigos em tempo real com a plataforma de mensagens rápida, segura e direto ao ponto. Sem frescura, só papo reto.
			</p>

			<div class="mt-2 flex flex-col justify-center gap-4 sm:flex-row lg:justify-start">
				<NavLink href="/cadastro" class="rounded-xl bg-blue-500 px-6 py-3 text-center font-bold text-white shadow-lg transition-all duration-300 hover:bg-blue-600 hover:shadow-blue-500/30">
					Criar Minha Conta Grátis
				</NavLink>
				<NavLink href="/login" class="rounded-xl bg-zinc-200 px-6 py-3 text-center font-semibold text-zinc-700 transition-all duration-300 hover:bg-zinc-300">
					Já tenho conta
				</NavLink>
			</div>
		</div>

		<!-- Mockup da Troca de Mensagens -->
		<div class="flex w-full justify-center lg:w-1/2">
			<div class="w-full max-w-md overflow-hidden rounded-2xl border border-zinc-200 bg-white shadow-xl">
				
				<!-- Topo do Chat (Mock) -->
				<div class="flex items-center gap-3 border-b border-zinc-200 bg-zinc-300 p-3">
					<div class="flex h-10 w-10 items-center justify-center rounded-full bg-blue-500 font-bold text-white">
						K
					</div>
					<div>
						<h4 class="text-sm font-bold text-zinc-800">Grupo dos Reis 👑</h4>
						<span class="text-xs text-zinc-500">Online agora</span>
					</div>
				</div>

				<!-- Balões de Mensagem -->
				<div class="flex min-h-[220px] flex-col gap-3 bg-zinc-50 p-4">
					<!-- Mensagem Recebida -->
					<div class="max-w-[80%] self-start rounded-2xl rounded-tl-none bg-zinc-200 p-3 text-sm text-zinc-700 shadow-sm">
						Fala meu King, testou o app de mensagem aí? 🚀
					</div>

					<!-- Mensagem Enviada -->
					<div class="max-w-[80%] self-end rounded-2xl rounded-tr-none bg-blue-500 p-3 text-sm text-white shadow-sm">
						Testei e tá voando! O Aspire + Blazor tá insano 🔥
					</div>

					<!-- Mensagem Recebida -->
					<div class="max-w-[80%] self-start rounded-2xl rounded-tl-none bg-zinc-200 p-3 text-sm text-zinc-700 shadow-sm">
						Aí sim! O verdadeiro King do Zap Zap!
					</div>
				</div>
			</div>
		</div>
	</section>

	<!-- RECURSOS / FEATURES (Cards simples) -->
	<section class="w-full bg-zinc-200 px-6 py-12 md:px-16">
		<div class="mx-auto flex max-w-7xl flex-col gap-8">
			<h2 class="text-center text-2xl font-bold text-zinc-800 md:text-3xl">
				Por que usar o King do Zap Zap?
			</h2>

			<div class="grid grid-cols-1 gap-6 md:grid-cols-3">
				<!-- Card 1 -->
				<div class="flex flex-col gap-2 rounded-xl border border-zinc-300 bg-zinc-100 p-6">
					<div class="text-3xl">⚡</div>
					<h3 class="text-lg font-bold text-zinc-800">Ultra Rápido</h3>
					<p class="text-sm text-zinc-600">Construído em WebAssembly e WebAPI para entregar mensagens sem travamento.</p>
				</div>

				<!-- Card 2 -->
				<div class="flex flex-col gap-2 rounded-xl border border-zinc-300 bg-zinc-100 p-6">
					<div class="text-3xl">🔒</div>
					<h3 class="text-lg font-bold text-zinc-800">Cookies HttpOnly</h3>
					<p class="text-sm text-zinc-600">Autenticação segura via tokens blindados contra ataques no front-end.</p>
				</div>

				<!-- Card 3 -->
				<div class="flex flex-col gap-2 rounded-xl border border-zinc-300 bg-zinc-100 p-6">
					<div class="text-3xl">👑</div>
					<h3 class="text-lg font-bold text-zinc-800">Interface de Rei</h3>
					<p class="text-sm text-zinc-600">Simplicidade e Tailwind CSS para você navegar sem complicação.</p>
				</div>
			</div>
		</div>
	</section>

	<!-- RODAPÉ (Footer) -->
	<footer class="border-t border-zinc-300 bg-zinc-300 p-4 text-center text-sm text-zinc-600">
		<p>© @DateTime.Now.Year King do Zap Zap - Todos os direitos reservados.</p>
	</footer>
</main>
