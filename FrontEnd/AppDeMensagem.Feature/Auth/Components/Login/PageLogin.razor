@using Microsoft.AspNetCore.Components.Routing


<section class="flex min-h-screen w-full bg-zinc-100">
	<!-- Formulário Esquerdo -->
	<article class="flex w-full items-center justify-center p-6 md:w-[50%] lg:w-[40%]">
		<FormLogin />
	</article>

	<!-- Painel Ilustrativo Direito (Visível em md/lg) -->
	<div class="bg-gradient-to-br hidden min-h-screen flex-col justify-between from-blue-500 to-blue-600 p-12 text-white md:flex md:w-[50%] lg:w-[60%]">
		<NavLink href="/" class="group flex w-max items-center gap-2 self-end">
			<span class="text-xl font-extrabold tracking-wide">King of Zap Zap</span>
			<div class="flex h-10 w-10 items-center justify-center rounded-full bg-white text-lg font-extrabold text-blue-600 shadow-md transition-transform group-hover:scale-105">
				K
			</div>
		</NavLink>

		<!-- Card Ilustrativo de Boas-Vindas -->
		<div class="mx-auto flex w-full max-w-lg flex-col gap-6">
			<div class="flex flex-col gap-2">
				<span class="text-4xl">👑</span>
				<h1 class="text-4xl leading-tight font-extrabold">
					Bem-vindo de volta, King of zap zap!
				</h1>
				<p class="text-lg text-blue-100">
					Acesse sua conta para continuar suas conversas em tempo real.
				</p>
			</div>

			<!-- Mockup Visual de Chat para o painel de Login -->
			<div class="flex flex-col gap-3 rounded-2xl border border-white/20 bg-white/10 p-4 shadow-xl backdrop-blur-md">
				<div class="max-w-[85%] self-start rounded-xl rounded-bl-none bg-white p-3 text-sm text-zinc-800 shadow">
					E aí, pronto para mandar as msgs do dia? 💬
				</div>
				<div class="max-w-[85%] self-end rounded-xl rounded-br-none border border-white/20 bg-blue-400/30 p-3 text-sm text-white shadow">
					Sempre! Bora logar no Zap! 🔥
				</div>
			</div>
		</div>

		<footer class="text-xs text-blue-200">
			© @DateTime.Now.Year King of Zap Zap. Todos os direitos reservados.
		</footer>
	</div>
</section>