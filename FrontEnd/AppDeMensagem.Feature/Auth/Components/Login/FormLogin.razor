@using Auth.Services
@inject LoginService LoginService
@inject NavigationManager navigation
@inject AuthenticationStateProvider authStateProvider

<div class="w-full max-w-md rounded-2xl border border-zinc-200 bg-white p-8 shadow-xl">

	<!-- Cabeçalho do Card -->
	<div class="mb-6 flex flex-col gap-1 text-center md:text-left">
		<h2 class="text-2xl font-extrabold text-zinc-800">Entrar na sua conta 🔑</h2>
		<p class="text-sm text-zinc-500">Digite seus dados para acessar a plataforma.</p>
	</div>

	<EditForm Model="LoginService.ModelUser"
			  OnValidSubmit="HandleSubmit"
			  class="flex flex-col gap-5"
			  OnInvalidSubmit="@(() =>
							  {
								  LoginService.ErrorLogin.Clear();
								  LoginService.ErrorLogin.Add("Preencha todos os campos corretamente.");
							  })">

		<DataAnnotationsValidator />

		<!-- Campo E-mail -->
		<div class="flex flex-col gap-1.5">
			<label class="text-sm font-bold text-zinc-700">E-mail:</label>
			<InputText @bind-Value="LoginService.ModelUser.Email"
					   placeholder="seu@email.com"
					   class="w-full rounded-xl border border-zinc-300 px-3.5 py-2.5 text-sm text-zinc-800 transition-all outline-none focus:border-blue-500 focus:ring-2 focus:ring-blue-200" />
			<ValidationMessage For="@(() => LoginService.ModelUser.Email)" class="text-xs text-red-500 font-medium" />
		</div>

		<!-- Campo Senha -->
		<div class="flex flex-col gap-1.5">
			<label class="text-sm font-bold text-zinc-700">Senha:</label>
			<InputText type="password"
					   @bind-Value="LoginService.ModelUser.Password"
					   placeholder="••••••••"
					   class="w-full rounded-xl border border-zinc-300 px-3.5 py-2.5 text-sm text-zinc-800 transition-all outline-none focus:border-blue-500 focus:ring-2 focus:ring-blue-200" />
			<ValidationMessage For="@(() => LoginService.ModelUser.Password)" class="text-xs text-red-500 font-medium" />
		</div>

		<!-- Exibição de Erros Globais -->
		@if (LoginService.ErrorLogin.Count > 0)
		{
			<div class="flex flex-col gap-1 rounded-xl border border-red-200 bg-red-50 p-3 text-xs font-semibold text-red-600">
				@foreach (string erro in LoginService.ErrorLogin)
				{
					<p>⚠️ @erro</p>
				}
			</div>
		}

		<!-- Botão Submeter -->
		<button type="submit"
				class="mt-2 w-full cursor-pointer rounded-xl bg-blue-500 py-3 text-sm font-bold text-white shadow-lg shadow-blue-500/25 transition-all duration-300 hover:bg-blue-600 active:scale-95">
			Entrar
		</button>

		<!-- Links de Suporte -->
		<div class="mt-2 flex flex-col gap-2 text-center text-xs text-zinc-500">
			<p>Não tem uma conta? <NavLink href="/cadastro" class="font-bold text-blue-500 hover:underline">Cadastre-se aqui!</NavLink></p>
			<NavLink href="/" class="text-zinc-400 transition-colors hover:text-zinc-600">Voltar para a página inicial</NavLink>
		</div>

	</EditForm>
</div>

@code {
	private async Task HandleSubmit()
	{
		LoginService.ErrorLogin.Clear();
		var result = await LoginService.LogarUser();
		if (result)
		{

			if (authStateProvider is CustomAuthStateProvider customAuth)
			{
				// Força o Blazor a rodar o GetAuthenticationStateAsync() novamente
				customAuth.NotifyUserAuthenticationState();
			}

			await Task.Yield();

			navigation.NavigateTo("/user/home");

		}
		else
		{
			LoginService.ErrorLogin.Add("E-mail ou senha inválidos. Tente novamente.");
		}
	}
}