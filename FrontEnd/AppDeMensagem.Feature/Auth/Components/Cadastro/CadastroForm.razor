@using AppDeMensagem.Feature.Auth.Models
@using Microsoft.AspNetCore.Components.Forms
@using Microsoft.AspNetCore.Components.Routing
@using Services
@inject CadastroService CadastroService
@inject NavigationManager Navigation

<div class="w-full max-w-lg rounded-2xl border border-zinc-200 bg-white p-8 shadow-xl">

	<!-- Cabeçalho do Card -->
	<div class="mb-6 flex flex-col gap-1 text-center md:text-left">
		<h2 class="text-2xl font-extrabold text-zinc-800">Crie sua conta 🚀</h2>
		<p class="text-sm text-zinc-500">Preencha os dados abaixo para se cadastrar.</p>
	</div>

	<EditForm Model="CadastroService.CadastroModel"
			  OnValidSubmit="HandleSubmit"
			  class="flex flex-col gap-5"
			  OnInvalidSubmit="@(() =>
								{
									CadastroService.ErrorCadastro.Clear();
									CadastroService.ErrorCadastro.Add("Por favor, preencha todos os campos corretamente.");
								})">

		<DataAnnotationsValidator />

		<!-- Linha 1: Nome e Perfil -->
		<div class="flex flex-col gap-4 sm:flex-row">
			<!-- Campo Nome -->
			<div class="flex flex-1 flex-col gap-1.5">
				<label class="text-sm font-bold text-zinc-700">Nome:</label>
				<InputText @bind-Value="CadastroService.CadastroModel.Name"
						   placeholder="Seu nome completo"
						   class="w-full rounded-xl border border-zinc-300 px-3 py-2 text-sm text-zinc-800 transition-all outline-none focus:border-blue-500 focus:ring-2 focus:ring-blue-200" />
				<ValidationMessage For="@(() => CadastroService.CadastroModel.Name)" class="text-xs text-red-500 font-medium" />
			</div>

			<!-- Campo Perfil -->
			<div class="flex w-full flex-col gap-1.5 sm:w-32">
				<label class="text-sm font-bold text-zinc-700">Perfil:</label>
				<InputSelect @bind-Value="CadastroService.CadastroModel.Profile"
							 class="w-full rounded-xl border border-zinc-300 bg-white px-3 py-2 text-sm text-zinc-800 transition-all outline-none focus:border-blue-500 focus:ring-2 focus:ring-blue-200">
					<option value="@ProfileUser.User">User</option>
					<option value="@ProfileUser.Admin">Admin</option>
				</InputSelect>
				<ValidationMessage For="@(() => CadastroService.CadastroModel.Profile)" class="text-xs text-red-500 font-medium" />
			</div>
		</div>

		<!-- Campo E-mail -->
		<div class="flex flex-col gap-1.5">
			<label class="text-sm font-bold text-zinc-700">E-mail:</label>
			<InputText @bind-Value="CadastroService.CadastroModel.Email"
					   placeholder="seu@email.com"
					   class="w-full rounded-xl border border-zinc-300 px-3 py-2 text-sm text-zinc-800 transition-all outline-none focus:border-blue-500 focus:ring-2 focus:ring-blue-200" />
			<ValidationMessage For="@(() => CadastroService.CadastroModel.Email)" class="text-xs text-red-500 font-medium" />
		</div>

		<!-- Linha 2: Senha e Confirmação (Com type="password") -->
		<div class="flex flex-col gap-4 sm:flex-row">
			<div class="flex flex-1 flex-col gap-1.5">
				<label class="text-sm font-bold text-zinc-700">Senha:</label>
				<InputText type="password"
						   @bind-Value="CadastroService.CadastroModel.PassWord"
						   placeholder="••••••••"
						   class="w-full rounded-xl border border-zinc-300 px-3 py-2 text-sm text-zinc-800 transition-all outline-none focus:border-blue-500 focus:ring-2 focus:ring-blue-200" />
				<ValidationMessage For="@(() => CadastroService.CadastroModel.PassWord)" class="text-xs text-red-500 font-medium" />
			</div>

			<div class="flex flex-1 flex-col gap-1.5">
				<label class="text-sm font-bold text-zinc-700">Confirmar Senha:</label>
				<InputText type="password"
						   @bind-Value="CadastroService.CadastroModel.ConfirmPassword"
						   placeholder="••••••••"
						   class="w-full rounded-xl border border-zinc-300 px-3 py-2 text-sm text-zinc-800 transition-all outline-none focus:border-blue-500 focus:ring-2 focus:ring-blue-200" />
				<ValidationMessage For="@(() => CadastroService.CadastroModel.ConfirmPassword)" class="text-xs text-red-500 font-medium" />
			</div>
		</div>

		<!-- Exibição de Erros Globais -->
		@if (CadastroService.ErrorCadastro.Count > 0)
		{
			<div class="flex flex-col gap-1 rounded-xl border border-red-200 bg-red-50 p-3 text-xs font-semibold text-red-600">
				@foreach (string erro in CadastroService.ErrorCadastro)
				{
					<p>⚠️ @erro</p>
				}
			</div>
		}

		<!-- Botão Submeter -->
		<button type="submit"
				class="mt-2 w-full cursor-pointer rounded-xl bg-blue-500 py-3 text-sm font-bold text-white shadow-lg shadow-blue-500/25 transition-all duration-300 hover:bg-blue-600 active:scale-95">
			Criar Minha Conta
		</button>

		<!-- Links Úteis -->
		<div class="mt-2 flex flex-col gap-2 text-center text-xs text-zinc-500">
			<p>Já possui uma conta? <NavLink href="/login" class="font-bold text-blue-500 hover:underline">Faça login aqui!</NavLink></p>
			<NavLink href="/" class="text-zinc-400 transition-colors hover:text-zinc-600">Voltar para a página inicial</NavLink>
		</div>

	</EditForm>
</div>

@code {
	private async Task HandleSubmit()
	{
		CadastroService.ErrorCadastro.Clear();
		var result = await CadastroService.RegisterUser();
		if (result)
		{
			Navigation.NavigateTo("/login");
		}
		else
		{
			CadastroService.ErrorCadastro.Add("Erro ao cadastrar. Verifique os dados e tente novamente.");
		}
	}
}